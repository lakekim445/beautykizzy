@model BeautyKizzy.Models.Usuario

@{
    ViewData["Title"] = "Crear cuenta";
}

<div class="container py-5">

    <div class="d-flex align-items-center justify-content-center">

        <div class="card-kizzy shadow-lg p-5" style="max-width:500px;width:100%;">

            <div class="text-center mb-4">
                <h2 class="titulo-serif mb-2">Crear cuenta</h2>
                <p class="text-muted">
                    Únete a BeautyKizzy y agenda tu primera cita.
                </p>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-action="Register" method="post">

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">Contraseña</label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Telefono" class="form-label fw-semibold"></label>
                        <input asp-for="Telefono" class="form-control" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Ciudad" class="form-label fw-semibold"></label>
                        <input asp-for="Ciudad" class="form-control" />
                        <span asp-validation-for="Ciudad" class="text-danger"></span>
                    </div>

                </div>

                <button type="submit" class="btn-primary-kizzy w-100 py-3 mt-2">
                    Registrarme
                </button>

            </form>

            <hr class="my-4" />

            <div class="text-center">

                <span class="text-muted">
                    ¿Ya tienes una cuenta?
                </span>

                <a asp-action="Login"
                   class="fw-semibold text-decoration-none"
                   style="color:var(--rosa-oscuro);">
                    Inicia sesión
                </a>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}