@model IEnumerable<BeautyKizzy.Models.Categoria>
@{
    ViewData["Title"] = "Categorías";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="titulo-serif mb-0">Categorías</h2>
        <p class="text-muted small mb-0">@Model.Count() categorías registradas</p>
    </div>
    <a asp-action="Create" class="btn-primary-kizzy px-4 py-2">+ Nueva categoría</a>
</div>

<div class="card-kizzy p-0">
    <table class="table table-kizzy mb-0">
        <thead>
            <tr>
                <th class="ps-3">Nombre</th>
                <th>Descripción</th>
                <th>Estado</th>
                <th class="text-end pe-3">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td class="ps-3 fw-semibold">@cat.Nombre</td>
                    <td class="text-muted small">@cat.Descripcion</td>
                    <td>
                        @if (cat.Activo)
                        {
                            <span class="stock-ok">Activa</span>
                        }
                        else
                        {
                            <span class="stock-bajo">Inactiva</span>
                        }
                    </td>
                    <td class="text-end pe-3">
                        <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-kizzy">Editar</a>
                        <a asp-action="Delete" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-kizzy">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
