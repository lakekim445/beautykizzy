@model BeautyKizzy.Models.Producto
@{
    ViewData["Title"] = "Editar producto";
    var proveedores = ViewBag.Proveedores as List<BeautyKizzy.Models.Proveedor> ?? new();
}

<div class="card-kizzy p-4" style="max-width:600px; margin:0 auto;">
    <h3 class="titulo-serif mb-1">Editar producto</h3>
    <p class="text-muted small mb-4">El stock se modifica desde "+ Stock" en el listado, no aquí</p>

    <div asp-validation-summary="ModelOnly" class="alert-kizzy-error mb-3"></div>

    <form method="post" asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label class="form-label fw-semibold">Nombre</label>
            <input asp-for="Nombre" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Unidad</label>
                <input asp-for="UnidadMedida" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Stock mínimo</label>
                <input asp-for="StockMinimo" type="number" step="0.01" class="form-control" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Costo unitario</label>
                <input asp-for="CostoUnitario" type="number" step="0.01" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Proveedor</label>
                <select asp-for="ProveedorId" class="form-select">
                    <option value="">Ninguno</option>
                    @foreach (var prov in proveedores)
                    {
                        <option value="@prov.Id">@prov.Nombre</option>
                    }
                </select>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <a asp-action="Index" class="btn btn-outline-kizzy px-4">Cancelar</a>
            <button type="submit" class="btn-primary-kizzy px-4">Guardar cambios</button>
        </div>
    </form>
</div>
