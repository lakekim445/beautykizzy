@model IEnumerable<BeautyKizzy.Models.Factura>
@{
    ViewData["Title"] = "Reporte de ventas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="titulo-serif mb-0">Reporte de ventas</h2>
        <p class="text-muted small mb-0">@((DateTime)ViewBag.FechaInicio).ToString("dd/MM/yyyy") — @((DateTime)ViewBag.FechaFin).ToString("dd/MM/yyyy")</p>
    </div>
    <form method="get" class="d-flex gap-2">
        <input type="date" name="fechaInicio" class="form-control form-control-sm" value="@((DateTime)ViewBag.FechaInicio).ToString(" yyyy-MM-dd")" />
        <input type="date" name="fechaFin" class="form-control form-control-sm" value="@((DateTime)ViewBag.FechaFin).ToString(" yyyy-MM-dd")" />
        <button type="submit" class="btn btn-sm btn-outline-kizzy">Filtrar</button>
    </form>
</div>

<div class="card-kizzy p-3 mb-3" style="background:var(--rosa-claro);">
    <div class="d-flex justify-content-between">
        <span class="fw-semibold">Total del período</span>
        <span class="fw-semibold fs-5" style="color:var(--rosa-oscuro);">@((decimal)ViewBag.Total).ToString("0.00")Bs</span>
    </div>
</div>

<div class="card-kizzy p-0">
    <table class="table table-kizzy mb-0">
        <thead>
            <tr>
                <th class="ps-3">N° Factura</th>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Método</th>
                <th class="text-end pe-3">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in Model)
            {
                <tr>
                    <td class="ps-3 small">@f.NumeroFactura</td>
                    <td>@f.Cliente?.Nombre</td>
                    <td class="small text-muted">@f.FechaEmision.ToString("dd/MM/yyyy")</td>
                    <td class="small text-muted">@f.MetodoPago?.Nombre</td>
                    <td class="text-end pe-3 fw-semibold">@f.Total.ToString("0.00")Bs</td>
                </tr>
            }
        </tbody>
    </table>
</div>
