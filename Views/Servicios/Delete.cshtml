@model BeautyKizzy.Models.Servicio
@{
    ViewData["Title"] = "Desactivar servicio";
}

<div class="card-kizzy p-4" style="max-width:500px; margin:0 auto;">
    <h3 class="titulo-serif mb-3">¿Desactivar este servicio?</h3>
    <p class="text-muted">No se eliminará permanentemente (para no afectar el historial de citas y facturas), pero dejará de aparecer en el catálogo.</p>

    <div class="card-kizzy p-3 mb-4" style="background:var(--rosa-claro);">
        <div class="fw-semibold">@Model.Nombre</div>
        <div class="small text-muted">@Model.Categoria?.Nombre · @Model.DuracionMinutos min · @Model.PrecioBase.ToString("0")Bs</div>
    </div>

    <form method="post" asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2 justify-content-end">
            <a asp-action="Index" class="btn btn-outline-kizzy px-4">Cancelar</a>
            <button type="submit" class="btn-primary-kizzy px-4">Sí, desactivar</button>
        </div>
    </form>
</div>
