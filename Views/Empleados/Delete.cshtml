@model BeautyKizzy.Models.Empleado
@{
    ViewData["Title"] = "Desactivar empleado";
}

<div class="card-kizzy p-4" style="max-width:500px; margin:0 auto;">
    <h3 class="titulo-serif mb-3">¿Desactivar este empleado?</h3>
    <p class="text-muted">No se eliminará su historial de reservas y facturas, pero ya no podrá iniciar sesión ni se le asignarán nuevas citas.</p>

    <div class="card-kizzy p-3 mb-4" style="background:var(--rosa-claro);">
        <div class="fw-semibold">@Model.Usuario?.Nombre</div>
        <div class="small text-muted">@Model.Usuario?.Email · @Model.Categoria?.Nombre</div>
    </div>

    <form method="post" asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2 justify-content-end">
            <a asp-action="Index" class="btn btn-outline-kizzy px-4">Cancelar</a>
            <button type="submit" class="btn-primary-kizzy px-4">Sí, desactivar</button>
        </div>
    </form>
</div>
