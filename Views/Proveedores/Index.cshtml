@model IEnumerable<BeautyKizzy.Models.Proveedor>
@{
    ViewData["Title"] = "Proveedores";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="titulo-serif mb-0">Proveedores</h2>
        <p class="text-muted small mb-0">@Model.Count() proveedores registrados</p>
    </div>
    <a asp-action="Create" class="btn-primary-kizzy px-4 py-2">+ Nuevo proveedor</a>
</div>

<div class="card-kizzy p-0">
    <table class="table table-kizzy mb-0">
        <thead>
            <tr>
                <th class="ps-3">Nombre</th>
                <th>Contacto</th>
                <th>Teléfono</th>
                <th>NIT</th>
                <th>Estado</th>
                <th class="text-end pe-3">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var prov in Model)
            {
                <tr>
                    <td class="ps-3 fw-semibold">@prov.Nombre</td>
                    <td class="text-muted small">@prov.Contacto</td>
                    <td class="text-muted small">@prov.Telefono</td>
                    <td class="text-muted small">@prov.Nit</td>
                    <td>
                        @if (prov.Activo)
                        {
                            <span class="stock-ok">Activo</span>
                        }
                        else
                        {
                            <span class="stock-bajo">Inactivo</span>
                        }
                    </td>
                    <td class="text-end pe-3">
                        <a asp-action="Edit" asp-route-id="@prov.Id" class="btn btn-sm btn-outline-kizzy">Editar</a>
                        <a asp-action="Delete" asp-route-id="@prov.Id" class="btn btn-sm btn-outline-kizzy">Desactivar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
