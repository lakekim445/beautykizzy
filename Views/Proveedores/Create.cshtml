@model BeautyKizzy.Models.Proveedor
@{
    ViewData["Title"] = "Nuevo proveedor";
}

<div class="card-kizzy p-4" style="max-width:550px; margin:0 auto;">
    <h3 class="titulo-serif mb-4">Nuevo proveedor</h3>

    <div asp-validation-summary="ModelOnly" class="alert-kizzy-error mb-3"></div>

    <form method="post" asp-action="Create">
        <div class="mb-3">
            <label class="form-label fw-semibold">Nombre</label>
            <input asp-for="Nombre" class="form-control" required />
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Persona de contacto</label>
                <input asp-for="Contacto" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Teléfono</label>
                <input asp-for="Telefono" class="form-control" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input asp-for="Email" type="email" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">NIT</label>
                <input asp-for="Nit" class="form-control" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Dirección</label>
            <input asp-for="Direccion" class="form-control" />
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <a asp-action="Index" class="btn btn-outline-kizzy px-4">Cancelar</a>
            <button type="submit" class="btn-primary-kizzy px-4">Guardar</button>
        </div>
    </form>
</div>
