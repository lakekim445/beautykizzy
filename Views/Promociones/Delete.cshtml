@model BeautyKizzy.Models.Promocion
@{
    ViewData["Title"] = "Desactivar promoción";
}

<div class="card-kizzy p-4" style="max-width:500px; margin:0 auto;">
    <h3 class="titulo-serif mb-3">¿Desactivar esta promoción?</h3>

    <div class="card-kizzy p-3 mb-4" style="background:var(--rosa-claro);">
        <div class="fw-semibold">@Model.Nombre</div>
        <div class="small text-muted">@Model.PrecioPromocion.ToString("0")Bs</div>
        <ul class="small text-muted mt-2 mb-0">
            @foreach (var ps in Model.PromocionServicios ?? new List<BeautyKizzy.Models.PromocionServicio>())
            {
                <li>@ps.Servicio?.Nombre</li>
            }
        </ul>
    </div>

    <form method="post" asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2 justify-content-end">
            <a asp-action="Index" class="btn btn-outline-kizzy px-4">Cancelar</a>
            <button type="submit" class="btn-primary-kizzy px-4">Sí, desactivar</button>
        </div>
    </form>
</div>
