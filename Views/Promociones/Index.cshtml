@model IEnumerable<BeautyKizzy.Models.Promocion>
@{
    ViewData["Title"] = "Promociones";
    var rol = Context.Session.GetString("UsuarioRol");
    var puedeGestionar = rol == BeautyKizzy.Models.Roles.Gerente || rol == BeautyKizzy.Models.Roles.Admin;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="titulo-serif mb-0">Promociones</h2>
        <p class="text-muted small mb-0">Combos a precio especial</p>
    </div>
    @if (puedeGestionar)
    {
        <a asp-action="Create" class="btn-primary-kizzy px-4 py-2">+ Nueva promoción</a>
    }
</div>

@if (!Model.Any())
{
    <div class="card-kizzy p-5 text-center">
        <i class="bi bi-gift fs-1" style="color:var(--rosa-oscuro);"></i>
        <p class="text-muted mt-2 mb-0">No hay promociones activas por el momento</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var promo in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card-kizzy p-4 h-100">
                    <span class="badge-rol badge-rol-gerente mb-2" style="width:fit-content;">Combo</span>
                    <div class="fw-semibold fs-5">@promo.Nombre</div>
                    <ul class="small text-muted mt-2 mb-3">
                        @foreach (var ps in promo.PromocionServicios ?? new List<BeautyKizzy.Models.PromocionServicio>())
                        {
                            <li>@ps.Servicio?.Nombre</li>
                        }
                    </ul>
                    <div class="fw-semibold mt-auto" style="color:var(--rosa-oscuro); font-size:1.3rem;">
                        @promo.PrecioPromocion.ToString("0")Bs
                    </div>
                    <div class="small text-muted">Válido hasta @promo.FechaFin.ToString("dd/MM/yyyy")</div>

                    @if (puedeGestionar)
                    {
                        <div class="d-flex gap-2 mt-3">
                            <a asp-action="Edit" asp-route-id="@promo.Id" class="btn btn-sm btn-outline-kizzy flex-fill">Editar</a>
                            <a asp-action="Delete" asp-route-id="@promo.Id" class="btn btn-sm btn-outline-kizzy flex-fill">Desactivar</a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
